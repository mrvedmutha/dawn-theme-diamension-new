{{ 'section-404.css' | asset_url | stylesheet_tag }}

<div class="custom-404-wrapper">
  <div class="custom-404">
    <div class="custom-404__content">

      {%- comment -%} 404 Image {%- endcomment -%}
      <span class="custom-404__graphic" aria-label="404 - Page not found">
        <img
          src="{{ '404-page/404-text-image.webp' | asset_url }}"
          alt="404 - Page not found"
          class="custom-404__graphic-image"
          loading="eager"
          width="1340"
          height="560"
        >
      </span>

      {%- comment -%} Error Message {%- endcomment -%}
      {%- if section.settings.error_message != blank -%}
        <p class="custom-404__message">{{ section.settings.error_message }}</p>
      {%- endif -%}

      {%- comment -%} Back to Home Link {%- endcomment -%}
      <a href="{{ routes.root_url }}" class="custom-404__link">
        {{ section.settings.link_text | default: "Back to Home" }}
      </a>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Custom 404",
  "settings": [
    {
      "type": "text",
      "id": "error_message",
      "label": "Error Message",
      "default": "The page you're looking for may have been moved or is no longer available."
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link Text",
      "default": "Back to Home"
    }
  ],
  "presets": [
    {
      "name": "Custom 404"
    }
  ]
}
{% endschema %}
