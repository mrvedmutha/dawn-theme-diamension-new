{% comment %}
  Renders a wishlist toggle button with specified size

  Parameters:
  - product: Product object (required)
  - size: 's' | 'm' | 'l' | 'xl' (required)
  - position: 'absolute' | 'relative' (optional, default: 'absolute')
  - custom_class: Additional CSS classes (optional)

  Usage:
  {% render 'wishlist-button', product: product, size: 'xl' %}
  {% render 'wishlist-button', product: product, size: 'm', position: 'relative' %}
{% endcomment %}

{% liquid
  assign position = position | default: 'absolute'

  case size
    when 'xl'
      assign button_size = '40px'
      assign svg_size = '24px'
    when 'l'
      assign button_size = '30px'
      assign svg_size = '19px'
    when 'm'
      assign button_size = '26px'
      assign svg_size = '18px'
    when 's'
      assign button_size = '24px'
      assign svg_size = '16px'
    else
      assign button_size = '30px'
      assign svg_size = '19px'
  endcase

  assign product_image = product.featured_image | image_url: width: 400
  if product.featured_image == blank
    assign product_image = ''
  endif
%}

<button
  class="wishlist-button wishlist-button--{{ size }} {% if position == 'relative' %}wishlist-button--relative{% endif %} {{ custom_class }}"
  data-wishlist-toggle
  data-product-id="{{ product.id }}"
  data-product-title="{{ product.title | escape }}"
  data-product-handle="{{ product.handle }}"
  data-product-image="{{ product_image }}"
  data-product-price="{{ product.price | money }}"
  aria-label="Add {{ product.title | escape }} to wishlist"
  type="button"
  style="--button-size: {{ button_size }}; --svg-size: {{ svg_size }};"
><svg width="{{ svg_size }}" height="{{ svg_size }}" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M20.59 4.96961C21.47 5.95961 22 7.25961 22 8.68961C22 15.6896 15.52 19.8196 12.62 20.8196C12.28 20.9396 11.72 20.9396 11.38 20.8196C8.48 19.8196 2 15.6896 2 8.68961C2 5.59961 4.49 3.09961 7.56 3.09961C9.38 3.09961 10.99 3.97961 12 5.33961C13.01 3.97961 14.63 3.09961 16.44 3.09961" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
