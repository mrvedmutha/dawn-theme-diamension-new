{% comment %}
  Wishlist Toast Notification
  Renders a toast notification for wishlist actions
  Should be included in layout/theme.liquid before </body>
{% endcomment %}

<div
  class="wishlist-toast"
  id="wishlist-toast"
  role="alert"
  aria-live="polite"
  aria-atomic="true"
  hidden
>
  <div class="wishlist-toast__content">
    <svg class="wishlist-toast__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M20.59 4.96961C21.47 5.95961 22 7.25961 22 8.68961C22 15.6896 15.52 19.8196 12.62 20.8196C12.28 20.9396 11.72 20.9396 11.38 20.8196C8.48 19.8196 2 15.6896 2 8.68961C2 5.59961 4.49 3.09961 7.56 3.09961C9.38 3.09961 10.99 3.97961 12 5.33961C13.01 3.97961 14.63 3.09961 16.44 3.09961" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <span class="wishlist-toast__message" id="wishlist-toast-message">
      Item added to wishlist
    </span>
    <a href="/pages/your-wishlist" class="wishlist-toast__link">
      View Wishlist
    </a>
  </div>
  <button
    class="wishlist-toast__close"
    aria-label="Close notification"
    type="button"
  >
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 4L4 12M4 4L12 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
  </button>
</div>
