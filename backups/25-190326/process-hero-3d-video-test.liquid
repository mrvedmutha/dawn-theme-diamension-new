{{ 'process-hero-3d-video-test.css' | asset_url | stylesheet_tag }}

{%- comment -%} Process Hero Section - Video-driven storytelling experiment {%- endcomment -%}
<div class="process-hero" data-section-id="{{ section.id }}" data-process-hero-video-test>
  {%- comment -%} Pinned Container - ScrollTrigger pins this {%- endcomment -%}
  <div class="process-hero__pinned" data-pinned-container style="--bg-color: {{ section.settings.background_color }}; --text-color: {{ section.settings.text_color }};">

    {%- comment -%} Layer 1: Background Color {%- endcomment -%}
    <div class="process-hero__bg">&nbsp;</div>

    {%- comment -%} Layer 3: Video (replaces canvas image sequence) {%- endcomment -%}
    <video
      class="process-hero__video"
      data-video-bg
      src="{{ 'Diamension_Page2_4K.mp4' | asset_url }}"
      muted
      playsinline
      preload="auto"
      aria-label="Process 3D background animation"
    ></video>

    {%- comment -%} Layer 5: Content Overlay {%- endcomment -%}
    <div class="process-hero__content">

      {%- comment -%} Intro Text (masked reveals) {%- endcomment -%}
      <div class="process-hero__intro" data-intro>
        {%- comment -%} Left Column: Small text + FROM SEED {%- endcomment -%}
        <div class="process-hero__intro-left-col">
          <div class="process-hero__mask">
            <span class="process-hero__intro-small">{{ section.settings.intro_small_text }}</span>
          </div>
          <div class="process-hero__mask">
            <span class="process-hero__intro-large">{{ section.settings.intro_left_text }}</span>
          </div>
        </div>

        {%- comment -%} Right Column: spacer + TO SPARKLE (spacer matches left small text height) {%- endcomment -%}
        <div class="process-hero__intro-right-col">
          <div class="process-hero__mask">
            <span class="process-hero__intro-small">&nbsp;</span>
          </div>
          <div class="process-hero__mask">
            <span class="process-hero__intro-large">{{ section.settings.intro_right_text }}</span>
          </div>
        </div>

        {%- comment -%} Mobile-only: small text left + FROM SEED TO SPARKLE combined right {%- endcomment -%}
        <div class="process-hero__intro--mobile">
          <div class="process-hero__mask">
            <span class="process-hero__intro-small">{{ section.settings.intro_small_text }}</span>
          </div>
          <div class="process-hero__mask">
            <span class="process-hero__intro-large">{{ section.settings.intro_left_text }} {{ section.settings.intro_right_text }}</span>
          </div>
        </div>
      </div>

      {%- comment -%} Phase Text Containers (3 phases, absolutely stacked) {%- endcomment -%}
      {%- assign phases = section.blocks | where: 'type', 'phase' | slice: 0, 3 -%}
      {%- for phase in phases -%}
        {%- assign phase_num = forloop.index -%}
        {%- assign step_num = phase.settings.step_number_override | default: phase_num -%}
        <div class="process-hero__phase" data-phase="{{ phase_num }}">
          {%- comment -%} Top-Right: Counter {%- endcomment -%}
          <div class="process-hero__phase-counter-container">
            <div class="process-hero__mask">
              <span class="process-hero__phase-counter">({{ step_num | prepend: '0' | slice: -2, 2 }}/03)</span>
            </div>
          </div>

          {%- comment -%} Left Column: Title {%- endcomment -%}
          <div class="process-hero__phase-left">
            <div class="process-hero__mask">
              <span class="process-hero__phase-title">{{ phase.settings.title }}</span>
            </div>
          </div>

          {%- comment -%} Right Column: Description {%- endcomment -%}
          <div class="process-hero__phase-right">
            <div class="process-hero__mask">
              <span class="process-hero__phase-description">{{ phase.settings.description }}</span>
            </div>
          </div>
        </div>
      {%- endfor -%}

      {%- comment -%} Progress Line + Diamond Dots + (KEEP SCROLLING) {%- endcomment -%}
      <div class="process-hero__progress-container" data-progress>
        {%- comment -%} Line Column (90%) {%- endcomment -%}
        <div class="process-hero__progress-line-col">
          <div class="process-hero__progress-line">&nbsp;</div>
          {%- for i in (1..3) -%}
            <div class="process-hero__progress-dot" data-dot="{{ i }}">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M11.8591 6.0095C7.97808 7.06216 7.06216 7.9781 6.0095 11.8591C5.9935 11.9181 5.90982 11.9181 5.89382 11.8591C4.84116 7.97808 3.92522 7.06216 0.0442346 6.0095C-0.0147449 5.9935 -0.0147449 5.90982 0.0442346 5.89382C3.92524 4.84116 4.84116 3.92522 5.89382 0.0442346C5.90982 -0.0147449 5.9935 -0.0147449 6.0095 0.0442346C7.06216 3.92524 7.9781 4.84116 11.8591 5.89382C11.9181 5.90982 11.9181 5.99352 11.8591 6.0095Z" fill="currentColor"/>
              </svg>
            </div>
          {%- endfor -%}
        </div>

        {%- comment -%} Scroll Hint Column (10%) {%- endcomment -%}
        <div class="process-hero__progress-scroll-col">
          <div class="process-hero__mask">
            <span class="process-hero__intro-scroll" data-scroll-hint>{{ section.settings.intro_scroll_text }}</span>
          </div>
        </div>
      </div>

      {%- comment -%} Definition Panel (4C's — post phases) {%- endcomment -%}
      {%- assign def_block = section.blocks | where: 'type', 'definition_panel' | first -%}
      {%- if def_block -%}
        <div class="process-hero__definition-panel" data-definition-panel>
          {%- comment -%} Left: heading + body {%- endcomment -%}
          <div class="process-hero__definition-left">
            {%- if def_block.settings.left_heading != blank -%}
              <div class="process-hero__mask">
                <span class="process-hero__definition-heading">{{ def_block.settings.left_heading }}</span>
              </div>
            {%- endif -%}
            {%- if def_block.settings.left_body != blank -%}
              <div class="process-hero__mask">
                <span class="process-hero__definition-body">{{ def_block.settings.left_body }}</span>
              </div>
            {%- endif -%}
          </div>

          {%- comment -%} Right: 4 definition rows {%- endcomment -%}
          <div class="process-hero__definition-right">
            {%- for i in (1..4) -%}
              {%- assign term_key = 'term_' | append: i -%}
              {%- assign def_key = 'definition_' | append: i -%}
              {%- if def_block.settings[term_key] != blank -%}
                <div class="process-hero__definition-row">
                  <div class="process-hero__mask">
                    <span class="process-hero__definition-term">{{ def_block.settings[term_key] }}</span>
                  </div>
                  {%- if def_block.settings[def_key] != blank -%}
                    <div class="process-hero__mask">
                      <span class="process-hero__definition-desc">{{ def_block.settings[def_key] }}</span>
                    </div>
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}

      {%- comment -%} Final Panel (Phase 5 — Diamension Promise) {%- endcomment -%}
      {%- assign final_block = section.blocks | where: 'type', 'final_panel' | first -%}
      {%- if final_block -%}
        <div class="process-hero__final-panel" data-final-panel>
          {%- comment -%} Center: left heading + right heading {%- endcomment -%}
          <div class="process-hero__final-center">
            <div class="process-hero__final-center-left">
              {%- if final_block.settings.small_text != blank -%}
                <div class="process-hero__mask">
                  <span class="process-hero__final-small">{{ final_block.settings.small_text }}</span>
                </div>
              {%- endif -%}
              {%- if final_block.settings.left_heading != blank -%}
                <div class="process-hero__mask">
                  <span class="process-hero__final-heading">{{ final_block.settings.left_heading }}</span>
                </div>
              {%- endif -%}
            </div>
            <div class="process-hero__final-center-right">
              {%- comment -%} Spacer matches left small text height so headings align {%- endcomment -%}
              <div class="process-hero__mask">
                <span class="process-hero__final-small">&nbsp;</span>
              </div>
              {%- if final_block.settings.right_heading != blank -%}
                <div class="process-hero__mask">
                  <span class="process-hero__final-heading">{{ final_block.settings.right_heading }}</span>
                </div>
              {%- endif -%}
            </div>
          </div>

          {%- comment -%} Bottom-left: label + body {%- endcomment -%}
          <div class="process-hero__final-bottom">
            {%- if final_block.settings.bottom_label != blank -%}
              <div class="process-hero__mask">
                <span class="process-hero__final-label">{{ final_block.settings.bottom_label }}</span>
              </div>
            {%- endif -%}
            {%- if final_block.settings.bottom_body != blank -%}
              <div class="process-hero__mask">
                <span class="process-hero__final-body">{{ final_block.settings.bottom_body }}</span>
              </div>
            {%- endif -%}
          </div>

          {%- comment -%} Mobile-only: small text + combined heading {%- endcomment -%}
          <div class="process-hero__final--mobile">
            {%- if final_block.settings.small_text != blank -%}
              <div class="process-hero__mask">
                <span class="process-hero__final-small">{{ final_block.settings.small_text }}</span>
              </div>
            {%- endif -%}
            {%- if final_block.settings.left_heading != blank or final_block.settings.right_heading != blank -%}
              <div class="process-hero__mask">
                <span class="process-hero__final-heading">{{ final_block.settings.left_heading }} {{ final_block.settings.right_heading }}</span>
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}

      {%- comment -%} Image Cards Viewport {%- endcomment -%}
      <div class="process-hero__cards-viewport">
        {%- for i in (1..3) -%}
          <div class="process-hero__cards-track" data-track="{{ i }}">
            {%- for block in section.blocks -%}
              {%- if block.type == 'card' and block.settings.phase_number == i -%}
                <div class="process-hero__card">
                  {%- if block.settings.image != blank -%}
                    <div class="process-hero__card-media">
                      <img
                        src="{{ block.settings.image | image_url: width: 800 }}"
                        alt="{{ block.settings.title | escape }}"
                        loading="lazy"
                        width="400"
                        height="225"
                      >
                      {%- if block.settings.title != blank -%}
                        <p class="process-hero__card-title">{{ block.settings.title }}</p>
                      {%- endif -%}
                    </div>
                  {%- elsif block.settings.video_url != blank -%}
                    <div class="process-hero__card-media">
                      <video
                        src="{{ block.settings.video_url }}"
                        muted
                        loop
                        playsinline
                        width="400"
                        height="225"
                      ></video>
                      {%- if block.settings.title != blank -%}
                        <p class="process-hero__card-title">{{ block.settings.title }}</p>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endfor -%}
      </div>

    </div>

    {%- comment -%} Transition Overlay (enter animation) {%- endcomment -%}
    <div class="process-hero__transition-overlay" data-transition-overlay>&nbsp;</div>
  </div>

  {%- comment -%} Spacer: video scroll + intro scroll (additive) {%- endcomment -%}
  {%- assign total_scroll_vh = section.settings.intro_scroll_vh | plus: section.settings.scroll_distance -%}
  <div class="process-hero__spacer" data-spacer style="height: {{ total_scroll_vh }}vh;">&nbsp;</div>

  {%- comment -%} Video config for JavaScript — virtualFrames keeps timing math identical to image-sequence version {%- endcomment -%}
  <script>
    window.processHeroVideoData = window.processHeroVideoData || {};
    {%- assign phase_blocks = section.blocks | where: 'type', 'phase' | slice: 0, 3 -%}
    window.processHeroVideoData['{{ section.id }}'] = {
      videoUrl: "{{ 'Diamension_Page2_4K.mp4' | asset_url }}",
      virtualFrames: {{ section.settings.frame_count }},
      introScrollVh: {{ section.settings.intro_scroll_vh | default: 10 }},
      scrollDistanceVh: {{ section.settings.scroll_distance }},
      transitionFrames: {{ section.settings.transition_frames | default: 20 }},
      phasesEndFrame: {{ section.settings.phases_end_frame | default: 600 }},
      phaseTimings: [
        {%- for phase in phase_blocks -%}
        { maskInStart: {{ phase.settings.mask_in_start_frame | default: 1 }}, maskOutStart: {{ phase.settings.mask_out_start_frame | default: 1 }} }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ],
      {%- assign def_block = section.blocks | where: 'type', 'definition_panel' | first -%}
      definitionPanel: {%- if def_block -%}{ maskInStart: {{ def_block.settings.mask_in_start_frame | default: 370 }}, maskOutStart: {{ def_block.settings.mask_out_start_frame | default: 550 }} }{%- else -%}null{%- endif -%},
      {%- assign final_block = section.blocks | where: 'type', 'final_panel' | first -%}
      finalPanel: {%- if final_block -%}{ revealFrame: {{ final_block.settings.reveal_frame | default: 525 }} }{%- else -%}null{%- endif -%}
    };
  </script>
</div>

{%- comment -%} Load header behavior script first (no defer - needs to run immediately) {%- endcomment -%}
<script src="{{ 'process-page-header.js' | asset_url }}"></script>

<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js" defer></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js" defer></script>
<script src="{{ 'process-hero-3d-video-test.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Process Hero (Video Test)",
  "class": "section-process-hero-3d-video-test",
  "settings": [
    {
      "type": "header",
      "content": "Intro Text"
    },
    {
      "type": "text",
      "id": "intro_small_text",
      "label": "Small Text",
      "default": "The Making of a CVD Diamond"
    },
    {
      "type": "text",
      "id": "intro_left_text",
      "label": "Left Text",
      "default": "FROM SEED"
    },
    {
      "type": "text",
      "id": "intro_right_text",
      "label": "Right Text",
      "default": "TO SPARKLE"
    },
    {
      "type": "text",
      "id": "intro_scroll_text",
      "label": "Scroll Hint",
      "default": "(KEEP SCROLLING)"
    },
    {
      "type": "header",
      "content": "Animation Settings"
    },
    {
      "type": "range",
      "id": "frame_count",
      "label": "Virtual Frame Count (Timing Reference)",
      "min": 50,
      "max": 800,
      "step": 10,
      "default": 750,
      "info": "Not used to load images — defines the timing scale for phase in/out frames below. Keep in sync with how you set phase timings."
    },
    {
      "type": "range",
      "id": "scroll_distance",
      "label": "Canvas Scroll Distance (vh)",
      "min": 500,
      "max": 3000,
      "step": 100,
      "default": 1500,
      "info": "Scroll height for the video animation (intro scroll is added on top)"
    },
    {
      "type": "range",
      "id": "intro_scroll_vh",
      "label": "Intro Scroll Distance (vh)",
      "min": 5,
      "max": 30,
      "step": 5,
      "default": 10,
      "info": "Additional scroll where video is frozen at frame 0 — intro text exits, Phase 1 enters"
    },
    {
      "type": "range",
      "id": "transition_frames",
      "label": "Transition Window (virtual frames)",
      "min": 5,
      "max": 50,
      "step": 5,
      "default": 20,
      "info": "Number of virtual frames each mask-in / mask-out animation spans"
    },
    {
      "type": "number",
      "id": "phases_end_frame",
      "label": "Phases End Frame",
      "default": 600,
      "info": "Virtual frame where all 3 phases complete — progress line and dots fade out, remaining video plays silently"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#fffaf5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#183754"
    }
  ],
  "blocks": [
    {
      "type": "phase",
      "name": "Phase",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Phase Title",
          "default": "ORIGIN"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Phase Description",
          "default": "The journey begins with a tiny diamond seed placed in a controlled chamber."
        },
        {
          "type": "range",
          "id": "step_number_override",
          "label": "Step Number (optional)",
          "min": 1,
          "max": 10,
          "step": 1,
          "default": 1,
          "info": "Leave at 1 to use automatic numbering"
        },
        {
          "type": "header",
          "content": "Frame Timing"
        },
        {
          "type": "number",
          "id": "mask_in_start_frame",
          "label": "Mask-In Start Frame",
          "default": 1,
          "info": "Virtual frame where this phase's text begins sliding in"
        },
        {
          "type": "number",
          "id": "mask_out_start_frame",
          "label": "Mask-Out Start Frame",
          "default": 1,
          "info": "Virtual frame where this phase's text begins sliding out"
        }
      ]
    },
    {
      "type": "card",
      "name": "Image Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card Image"
        },
        {
          "type": "url",
          "id": "video_url",
          "label": "Video URL (optional)",
          "info": "If provided, overrides image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Card Title"
        },
        {
          "type": "range",
          "id": "phase_number",
          "label": "Phase Number",
          "min": 1,
          "max": 3,
          "step": 1,
          "default": 1,
          "info": "Which phase this card belongs to"
        }
      ]
    },
    {
      "type": "definition_panel",
      "name": "Definition Panel (4C's)",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "Left Column"
        },
        {
          "type": "text",
          "id": "left_heading",
          "label": "Heading",
          "default": "Diamond Quality, Defined"
        },
        {
          "type": "textarea",
          "id": "left_body",
          "label": "Body Text",
          "default": "Diamond excellence is defined by four universal parameters — the 4C's."
        },
        {
          "type": "header",
          "content": "Right Column — Definitions"
        },
        {
          "type": "text",
          "id": "term_1",
          "label": "Term 1",
          "default": "Cut"
        },
        {
          "type": "textarea",
          "id": "definition_1",
          "label": "Definition 1",
          "default": "Determines brilliance and light performance."
        },
        {
          "type": "text",
          "id": "term_2",
          "label": "Term 2",
          "default": "Clarity"
        },
        {
          "type": "textarea",
          "id": "definition_2",
          "label": "Definition 2",
          "default": "Measures natural inclusions and purity."
        },
        {
          "type": "text",
          "id": "term_3",
          "label": "Term 3",
          "default": "Color"
        },
        {
          "type": "textarea",
          "id": "definition_3",
          "label": "Definition 3",
          "default": "Evaluates the absence of color."
        },
        {
          "type": "text",
          "id": "term_4",
          "label": "Term 4",
          "default": "Carat"
        },
        {
          "type": "textarea",
          "id": "definition_4",
          "label": "Definition 4",
          "default": "Defines weight, not size."
        },
        {
          "type": "header",
          "content": "Frame Timing"
        },
        {
          "type": "number",
          "id": "mask_in_start_frame",
          "label": "Mask-In Start Frame",
          "default": 370,
          "info": "Virtual frame where the panel begins sliding in"
        },
        {
          "type": "number",
          "id": "mask_out_start_frame",
          "label": "Mask-Out Start Frame",
          "default": 550,
          "info": "Virtual frame where the panel begins sliding out"
        }
      ]
    },
    {
      "type": "final_panel",
      "name": "Final Panel (Phase 5)",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "Center Left"
        },
        {
          "type": "text",
          "id": "small_text",
          "label": "Small Text",
          "default": "The"
        },
        {
          "type": "text",
          "id": "left_heading",
          "label": "Left Heading",
          "default": "DIAMENSION"
        },
        {
          "type": "header",
          "content": "Center Right"
        },
        {
          "type": "text",
          "id": "right_heading",
          "label": "Right Heading",
          "default": "PROMISE"
        },
        {
          "type": "header",
          "content": "Bottom Left"
        },
        {
          "type": "text",
          "id": "bottom_label",
          "label": "Label",
          "default": "Final Creation"
        },
        {
          "type": "textarea",
          "id": "bottom_body",
          "label": "Body Text",
          "default": "Ethically grown. Scientifically perfected. Unmistakably brilliant."
        },
        {
          "type": "header",
          "content": "Frame Timing"
        },
        {
          "type": "number",
          "id": "reveal_frame",
          "label": "Reveal Start Frame",
          "default": 525,
          "info": "Virtual frame where the panel begins revealing. Groups stagger: center-left → center-right → bottom-left"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Process Hero (Video Test)",
      "blocks": [
        {
          "type": "phase",
          "settings": {
            "title": "ORIGIN",
            "description": "The journey begins with a tiny diamond seed placed in a controlled chamber."
          }
        },
        {
          "type": "phase",
          "settings": {
            "title": "THE REVEAL",
            "description": "Carbon atoms bond layer by layer, growing the diamond over weeks."
          }
        },
        {
          "type": "phase",
          "settings": {
            "title": "THE CUT",
            "description": "Master cutters shape the raw diamond into brilliant perfection."
          }
        }
      ]
    }
  ]
}
{% endschema %}
